        <mxCell id="vDUwpMr7bvmIeesvooGg-9" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="METODOS PUBLICOS&lt;div&gt;+ producto constructor vacio para inicializar sin datos&amp;nbsp;&lt;/div&gt;&lt;div&gt;+producto codigo strng nombre string&lt;/div&gt;&lt;div&gt;precio double stoock int constructor completo que usa seteers&lt;/div&gt;&lt;div&gt;+set precio precio double void&amp;nbsp; setter con validaccion para que el precio no sea negativo&amp;nbsp;&lt;/div&gt;&lt;div&gt;+set stoock stoock int void seter con validacion para que el stoojk no sea&amp;nbsp;&lt;/div&gt;&lt;div&gt;negativo&lt;/div&gt;" vertex="1">
