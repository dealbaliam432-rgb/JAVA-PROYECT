        <mxCell id="vDUwpMr7bvmIeesvooGg-7" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="CLASE EMPLEADO&lt;div&gt;representa a un empleado en el sistema&lt;/div&gt;&lt;div&gt;ATRI PRIVADOS&lt;/div&gt;&lt;div&gt;nom string&lt;/div&gt;&lt;div&gt;edad in&lt;/div&gt;&lt;div&gt;METODOS PUBLICOS&lt;/div&gt;&lt;div&gt;+ empleado nombre string edad int constructor completo que usa SETEDAD&amp;nbsp;&lt;/div&gt;&lt;div&gt;+setedad edad int void seter con validacion para que la edad no sea negativa&lt;/div&gt;&lt;div&gt;+getnombre string geter para obtener el nombre&lt;/div&gt;" vertex="1">
