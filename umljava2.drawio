        <mxCell id="vDUwpMr7bvmIeesvooGg-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="CLASE CLIENTE&lt;div&gt;parte del paquete model representa un cliente del sistema&lt;/div&gt;&lt;div&gt;ATRIBITOS PRIVADOS&lt;/div&gt;&lt;div&gt;ced string&lt;/div&gt;&lt;div&gt;nom string&lt;/div&gt;&lt;div&gt;METODOS PUBLICOS&lt;/div&gt;&lt;div&gt;+cliente cedula string nom string&lt;/div&gt;&lt;div&gt;CONSTRUCTOR COMPLETO&lt;/div&gt;" vertex="1">
