        <mxCell id="vDUwpMr7bvmIeesvooGg-8" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="CLASE PRODUCTO&lt;div&gt;define un producto individual con su precio y stook (INVENTARIO)&lt;/div&gt;&lt;div&gt;ATRIBUTOS PRIV&lt;/div&gt;&lt;div&gt;codigo string&lt;/div&gt;&lt;div&gt;nombre string&lt;/div&gt;&lt;div&gt;precio doble&amp;nbsp;&lt;/div&gt;&lt;div&gt;stook int&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="150" x="690" as="geometry" />
