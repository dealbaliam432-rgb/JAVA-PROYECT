        </mxCell>
        <mxCell id="vDUwpMr7bvmIeesvooGg-17" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="CLASE INVENTARIO&lt;div&gt;gestiona la coleccion completa de productos disponibles&lt;/div&gt;&lt;div&gt;atributos privados&lt;/div&gt;&lt;div&gt;listaproductos arraylist colecion para el sistema de almacenamiento temp de productos&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;metodos publicos&lt;/div&gt;&lt;div&gt;+inventario const completo que inicializa el array list&lt;/div&gt;&lt;div&gt;+agregarproducto&amp;nbsp;&lt;/div&gt;&lt;div&gt;+buscar por codigo codigo string metodo funcional para buscar un producto especifico en el codigo&lt;/div&gt;" vertex="1">
