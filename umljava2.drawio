        <mxCell id="vDUwpMr7bvmIeesvooGg-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="CLASE APP&amp;nbsp;&lt;div&gt;esta clase es el punto de entrada&amp;nbsp; de la aplicacion y&amp;nbsp;&lt;/div&gt;&lt;div&gt;contiene el metodo prinncipal&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;METODOS&lt;/div&gt;&lt;div&gt;+main args string boids&lt;/div&gt;" vertex="1">
