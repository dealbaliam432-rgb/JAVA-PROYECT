        </mxCell>
        <mxCell id="vDUwpMr7bvmIeesvooGg-13" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="CLASE VENTA&amp;nbsp;&lt;div&gt;hace una transacion de venta completa incluyendo el cliente empleado y los productos adquiridos&lt;/div&gt;&lt;div&gt;atributos priv&lt;/div&gt;&lt;div&gt;idventa int&lt;/div&gt;&lt;div&gt;cliente cliente&lt;/div&gt;&lt;div&gt;emple emple&lt;/div&gt;&lt;div&gt;listaitem array list&lt;/div&gt;&lt;div&gt;coleccion para almacenamientos temp de los item de ventas&amp;nbsp;&lt;/div&gt;&lt;div&gt;totalventa double&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;metodos publicos&lt;/div&gt;&lt;div&gt;+venta idventa int constructor completo que inicializa el arraylist&lt;/div&gt;&lt;div&gt;getcliente cliente geter para obtener cliente asociado&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
